---
interface Project {
  tag: string;
  metric: string;
  title: string;
  description: string;
  stack: string[];
}

const projects: Project[] = [
  {
    tag: 'Performance Engineering',
    metric: '36 hrs → 2 hrs',
    title: 'Matching System Optimization',
    description:
      'A nightly matching job that took 36 hours was breaking SLAs and blocking downstream reports. Profiled the query planner, rewrote the core algorithm, and added targeted indexes. Job now completes in under 2 hours — no infrastructure changes required.',
    stack: ['PostgreSQL', 'Node.js', 'Query Optimization'],
  },
  {
    tag: 'System Reliability',
    metric: '3 hrs → 5 min',
    title: 'Automated Incident Response',
    description:
      'On-call engineers were spending 3+ hours per incident manually correlating logs across services. Built an automated triage pipeline that detects anomalies, traces root cause across distributed logs, and fires a structured Slack alert. Mean time to resolution dropped by 97%.',
    stack: ['Node.js', 'AWS CloudWatch', 'Slack API', 'n8n'],
  },
  {
    tag: 'Full-Stack Architecture',
    metric: '0 → production',
    title: 'Transport Management System',
    description:
      'Greenfield TMS for a logistics client — designed the data model, built the REST API, and delivered the frontend. Handles order lifecycle, driver assignment, and real-time status updates. Deployed on AWS with MongoDB for flexible schema evolution.',
    stack: ['Node.js', 'MongoDB', 'AWS', 'React'],
  },
  {
    tag: 'AI Integration',
    metric: 'Manual → automated',
    title: 'AI-Powered Content Pipeline',
    description:
      'Content team was manually drafting, scheduling, and publishing across three platforms — 4–5 hours per week. Built an n8n pipeline that ingests raw notes, runs them through Claude API for drafting and formatting, then queues for review and auto-publishes. Team now spends 30 minutes reviewing instead of writing.',
    stack: ['n8n', 'Claude API', 'Node.js', 'Webhook'],
  },
];
---

<section id="work">
  <div class="container">
    <p class="section-label">Selected projects</p>
    <h2>Work</h2>
    <div class="grid">
      {
        projects.map((p) => (
          <div class="card">
            <span class="tag">{p.tag}</span>
            <p class="metric">{p.metric}</p>
            <h3>{p.title}</h3>
            <p class="desc">{p.description}</p>
            <div class="stack">
              {p.stack.map((s) => (
                <span class="tag">{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 2.5rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .metric {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
    max-width: none;
  }

  .card h3 { color: var(--color-text); }

  .desc {
    color: var(--color-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    max-width: none;
    flex: 1;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
</style>
