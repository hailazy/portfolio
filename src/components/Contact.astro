<section id="contact">
  <div class="container">
    <p class="section-label">Get in touch</p>
    <h2>Let's build something</h2>
    <p class="body-text">
      Available for select freelance on Upwork and direct contracts.<br />
      Interested in collaboration on game dev tools, AI pipelines, or automation.<br />
      Response: within 24 hours.
    </p>
    <div class="cta-row">
      <a
        href="https://www.upwork.com/freelancers/~01c1234placeholder"
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Upwork Profile →
      </a>
    </div>
    <div class="links">
      <a href="mailto:thanhhai9x98@gmail.com" class="link">thanhhai9x98@gmail.com</a>
      <span class="sep">·</span>
      <a
        href="https://github.com/haingt-dev"
        class="link"
        target="_blank"
        rel="noopener noreferrer"
      >GitHub</a>
      <span class="sep">·</span>
      <a
        href="https://linkedin.com/in/haingt-dev"
        class="link"
        target="_blank"
        rel="noopener noreferrer"
      >LinkedIn</a>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 1.25rem; }

  .body-text {
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .cta-row { margin-bottom: 2rem; }

  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .link {
    color: var(--color-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .link:hover { color: var(--color-accent); }

  .sep { color: var(--color-border); }
</style>
