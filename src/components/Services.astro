---
interface Service {
  title: string;
  description: string;
  tags: string[];
}

const services: Service[] = [
  {
    title: 'Backend Architecture & APIs',
    description:
      "API design, database optimization, AWS infrastructure. 7 years of production systems — I've handled 15M+ record datasets and cut processing times by 95%. I know where things break before they do.",
    tags: ['Node.js', 'AWS', 'MongoDB', 'Redis', 'PostgreSQL'],
  },
  {
    title: 'AI Integration & Automation',
    description:
      'Connect your tools. Automate the repetitive parts. Build pipelines that actually run — Claude API, OpenAI, n8n, custom flows. Not the hype, just the plumbing.',
    tags: ['Claude API', 'OpenAI', 'n8n', 'Node.js', 'MCP'],
  },
];
---

<section id="services">
  <div class="container">
    <p class="section-label">Available for hire</p>
    <h2>Services</h2>
    <div class="grid">
      {
        services.map((s) => (
          <div class="card">
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <div class="tags">
              {s.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <p class="availability-note">
      Available for select projects on Upwork and direct contracts.
      <a href="#contact" class="note-link">Get in touch →</a>
    </p>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 2.5rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card h3 { color: var(--color-text); }

  .card p {
    color: var(--color-muted);
    font-size: 0.95rem;
    max-width: none;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .availability-note {
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .note-link {
    color: var(--color-accent);
    margin-left: 0.25rem;
  }
</style>
