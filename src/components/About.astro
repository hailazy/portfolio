---
const skills = {
  Backend:    ['Node.js', 'AWS', 'MongoDB', 'Redis', 'PostgreSQL', 'SQL'],
  AI:         ['Claude API', 'OpenAI API', 'MCP', 'n8n'],
  'Game Dev': ['Godot 4.6', 'GDScript'],
  Video:      ['Remotion', 'viXTTS', 'Gemini API'],
  Tools:      ['Git', 'Linux', 'Docker', 'Cloudflare'],
};
---

<section id="about">
  <div class="container">
    <p class="section-label reveal">Background</p>
    <h2 class="reveal">About</h2>
    <div class="layout reveal">
      <div class="bio">
        <p>
          I'm a backend developer from Vietnam building my way out of employment.
          After 7 years writing Node.js and AWS at scale, I'm now building an indie
          game dev ecosystem — tools, games, and content pipelines where every piece
          serves the others.
        </p>
        <p>
          Co-founded <strong>Bookie</strong>, a Vietnamese reading community, 9+ years ago.
          Now building an AI video pipeline for it — books to narrated video, one command.
          Building <strong>Wildtide</strong>, an indirect city builder in Godot.
          Building <strong>Agent Hub</strong> to make Claude Code actually useful across projects.
        </p>
        <p>
          Systems thinker. City builder addict. First kid arriving April 2026.
          Based in Ho Chi Minh City.
        </p>
      </div>
      <div class="skills reveal">
        {
          Object.entries(skills).map(([category, items]) => (
            <div class="skill-group">
              <p class="skill-category">{category}</p>
              <div class="skill-items">
                {items.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 2.5rem; }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .layout {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .bio p {
    color: var(--color-muted);
    line-height: 1.8;
  }

  .bio strong {
    color: var(--color-text);
    font-weight: 600;
    box-shadow: inset 0 -4px 0 var(--color-accent-glow);
    transition: background-color 0.2s ease-out, box-shadow 0.2s ease-out;
    padding-inline: 0.1em;
    border-radius: 2px;
  }

  .bio strong:hover {
    background-color: var(--color-accent-glow);
    box-shadow: inset 0 -1.5em 0 var(--color-accent-glow);
  }

  .tag {
    cursor: default;
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .skill-group { display: flex; flex-direction: column; gap: 0.5rem; }

  .skill-category {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    max-width: none;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
